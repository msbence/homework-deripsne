global:
  scrape_interval: 30s
  evaluation_interval: 30s
  scrape_timeout: 10s

scrape_configs:
  - job_name: "prometheus_exporter"
    static_configs:
      - targets:
        - localhost:9090
  - job_name: "node_exporter"
    static_configs:
      - targets:
        - {{ ansible_facts['default_ipv4']['address'] }}:9100
  - job_name: "mongodb_exporter"
    static_configs:
      - targets:
        - {{ ansible_facts['default_ipv4']['address'] }}:9216
