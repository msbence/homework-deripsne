[Unit]
Description=Node Exporter
Wants=network-online.target
After=network-online.target

[Service]
User=node_exporter
Group=node_exporter
Type=simple
Restart=on-failure
WorkingDirectory=/monitoring/node_exporter
ExecStart=/monitoring/node_exporter/node_exporter

[Install]
WantedBy=multi-user.target
